param (
    [Parameter(Mandatory=$true, Position=0)]
    [string]$FunctionName,

    [Parameter(Position=1)]
    [string]$Command,

    [Parameter(Position=2, ValueFromRemainingArguments=$true)]
    [string[]]$CommandArgs
)

if (-not $Command -and $FunctionName -match '\s') {
    $Parts = $FunctionName -split '\s+', 2
    $FunctionName = $Parts[0]

    if ($Parts.Count -gt 1) {
        $Command = $Parts[1]
    }
}

