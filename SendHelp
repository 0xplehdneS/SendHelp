Write-Host "_________________________________________`n`nRoger that. Cooking output (robot noises) `n_________________________________________`n"

switch ($FunctionName) {

    "Get-Version" {
        Get-Version
    }

    "Run-Command" {
        if (-not $Command) {
            Write-Error "Run-Command requires a command argument."
            exit 1
        }

        Run-Command $Command $CommandArgs
    }

    "Run-EncodedCommand" {
        if (-not $Command) {
            Write-Error "Run-DecodedCommandPreview requires an encoded command."
            exit 1
        }

        Run-EncodedCommand $Command
    }

    "Run-ZoneIdentifier" {
        Write-Host ""

        if (-not $Command) {
            Write-Error "Run-ZoneIdentifier requires a file path."
            exit 1
        }

        Run-ZoneIdentifier $Command
    }

    "Run-RunMRU" {
        Run-RunMRU
    }

    "Run-RegistryQuery" {
        if (-not $Command) {
            Write-Error "Run-RegistryQuery requires a registry path."
            Write-Error 'Example: run SendHelp "Run-RegistryQuery HKEY_USERS\S-1-5-21-1436740266-4157994359-4067780582-1000\SOFTWARE\POCKey"'
            exit 1
        }

        Run-RegistryQuery $Command
    }

    "Run-Prefetch" {
        Run-Prefetch
    }

    "Run-PrefetchQuery" {
        if (-not $Command) {
            Write-Error 'Usage: run SendHelp "Run-PrefetchQuery <process name>"'
            exit 1
        }

        Run-PrefetchQuery $Command
    }

    "Run-Processes" {
        Run-Processes
    }

    "Run-MiniDumpProcess" {
        if (-not $Command) {
            Write-Error "Run-MiniDumpProcess requires a Process ID."
            exit 1
        }

        Run-MiniDumpProcess $Command
    }

    default { Write-Error "Unknown function: $FunctionName" }
}